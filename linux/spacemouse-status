#!/bin/bash
# Quick health check for CAD Mouse MK2 Linux integration.

ok()  { printf "  %-16s \e[32m%s\e[0m\n" "$1" "$2"; }
warn(){ printf "  %-16s \e[33m%s\e[0m\n" "$1" "$2"; }
fail(){ printf "  %-16s \e[31m%s\e[0m\n" "$1" "$2"; }

echo "CAD Mouse MK2 — status"
echo

# USB device
# Set VID:PID to match your device (run `lsusb` to find it)
DEVICE_ID="${CAD_MOUSE_ID:-}"
if [ -n "$DEVICE_ID" ] && lsusb | grep -q "$DEVICE_ID"; then
    ok "device" "connected"
else
    fail "device" "NOT FOUND — plug in the mouse"
fi

# spacenavd
if systemctl is-active --quiet spacenavd; then
    ok "spacenavd" "running"
else
    fail "spacenavd" "stopped  →  sudo systemctl restart spacenavd"
fi

# spacenav-ws
if systemctl --user is-active --quiet spacenav-ws 2>/dev/null; then
    ok "spacenav-ws" "running"
else
    fail "spacenav-ws" "stopped  →  systemctl --user restart spacenav-ws"
fi

# spnav-buttons
if systemctl --user is-active --quiet spnav-buttons 2>/dev/null; then
    ok "spnav-buttons" "running"
else
    fail "spnav-buttons" "stopped  →  systemctl --user restart spnav-buttons"
fi

# hidraw
HIDRAW=$(ls /dev/input/by-id/ 2>/dev/null | grep "CAD_Mouse_MK2.*hidraw" | head -1)
if [ -n "$HIDRAW" ]; then
    ok "hidraw" "$HIDRAW"
else
    warn "hidraw" "not found (device may need replug)"
fi

# spnav socket
if [ -S /var/run/spnav.sock ]; then
    ok "spnav.sock" "exists"
else
    fail "spnav.sock" "missing — spacenavd not reading device"
fi

echo
