#!/bin/bash
# Called by udev when the CAD Mouse MK2 is plugged in.
# Finds the logged-in user and restarts their spacenav user services.
set -e

# Find the first non-root interactive user session
ACTIVE_USER=$(loginctl list-sessions --no-legend 2>/dev/null \
    | awk '$3 != "root" {print $3; exit}')

if [ -z "$ACTIVE_USER" ]; then
    ACTIVE_USER=$(who | awk '$1 != "root" {print $1; exit}')
fi

if [ -z "$ACTIVE_USER" ]; then
    exit 0
fi

systemctl --user --machine="${ACTIVE_USER}@.host" \
    restart spacenav-ws spnav-buttons 2>/dev/null || true
